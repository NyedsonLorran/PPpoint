spring:
  datasource:
    url: jdbc:postgresql://SEU_HOST:6543/postgres
    username: SEU_USUARIO
    password: SUA_SENHA

    hikari:
      data-source-properties:
        prepareThreshold: 0

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true

  properties:
    hibernate:
      format_sql: true

server:
  port: 8080

